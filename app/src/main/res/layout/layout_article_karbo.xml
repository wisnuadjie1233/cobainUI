<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Garis Handle Atas -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"
            android:background="#3A3A3C" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DIET &amp; BERAT BADAN"
            android:textColor="#FF6F43"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/spacelight"
            android:text="Apa itu Karbohidrat Baik dan Buruk?"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="20dp"
            android:background="?attr/colorSurfaceVariant" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="6dp"
            android:text="Karbohidrat adalah sumber energi utama bagi tubuh. Namun tidak semua karbohidrat memberikan manfaat yang sama. Karbohidrat kompleks dicerna lebih lambat sehingga memberikan energi yang lebih stabil, sedangkan karbohidrat sederhana lebih cepat diserap tubuh."
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="15sp" />

        <!-- CONTOH SEDERHANA -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Contoh Karbohidrat:"
            android:textColor="?android:attr/textColorPrimary"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="4dp"
            android:text="Karbohidrat baik: beras merah, oatmeal, kentang, ubi, dan roti gandum.\nKarbohidrat sederhana: minuman manis, permen, kue, dan roti putih."
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="14sp" />

        <!-- CARA MEMILIH -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Cara Memilih Karbohidrat:"
            android:textColor="?android:attr/textColorPrimary"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="4dp"
            android:text="• Pilih karbohidrat yang minim proses\n• Perbanyak makanan tinggi serat\n• Kurangi makanan dengan gula tambahan"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="14sp" />

        <!-- KARTU TIPS -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#1C1C1E"
            app:cardCornerRadius="16dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡 Tips Penting"
                    android:textColor="#FF6F43"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Karbohidrat tidak perlu dihindari sepenuhnya. Pilih karbohidrat kompleks agar energi lebih stabil dan rasa kenyang bertahan lebih lama."
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- TOMBOL TUTUP -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_close_karbo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="24dp"
            android:text="Saya Mengerti"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:backgroundTint="#FF6F43"
            app:cornerRadius="16dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>