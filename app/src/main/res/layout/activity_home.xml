<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1C1C1E"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    tools:context=".HomeActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="100dp">

        <!-- Header -->
        <ImageView
            android:id="@+id/user_avatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_user_avatar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/welcome_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Selamat Pagi, Dewa!"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:layout_constraintStart_toEndOf="@+id/user_avatar"
            app:layout_constraintTop_toTopOf="@+id/user_avatar"
            app:layout_constraintBottom_toBottomOf="@+id/user_avatar"/>

        <ImageView
            android:id="@+id/notification_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:src="@drawable/ic_notification"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/user_avatar"
            app:layout_constraintBottom_toBottomOf="@+id/user_avatar"/>

        <ImageView
            android:id="@+id/crown_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:src="@drawable/ic_crown"
            app:layout_constraintEnd_toStartOf="@+id/notification_icon"
            app:layout_constraintTop_toTopOf="@+id/user_avatar"
            app:layout_constraintBottom_toBottomOf="@+id/user_avatar"/>

        <!-- Date Picker -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/date_recycler_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/user_avatar"
            tools:listitem="@layout/item_date"
            tools:itemCount="7"/>

        <!-- Calories Section -->
        <TextView
            android:id="@+id/kalori_harian_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:text="Kalori Harian Anda"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/date_recycler_view" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/calories_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="#6A5AE0"
            app:cardCornerRadius="20dp"
            app:layout_constraintTop_toBottomOf="@+id/kalori_harian_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <TextView
                    android:id="@+id/total_kalori_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Kalori"
                    android:textColor="#FFFFFF"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.mikhaellopez.circularprogressbar.CircularProgressBar
                    android:id="@+id/calories_progress_bar"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    app:cpb_background_progressbar_color="#B3AEEA"
                    app:cpb_background_progressbar_width="15dp"
                    app:cpb_progress="65"
                    app:cpb_progress_direction="to_right"
                    app:cpb_progressbar_color="#000000"
                    app:cpb_progressbar_width="15dp"
                    app:cpb_round_border="true"
                    app:layout_constraintTop_toBottomOf="@+id/total_kalori_label"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="16dp"/>

                <TextView
                    android:id="@+id/calories_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1672"
                    android:textColor="#000000"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    app:layout_constraintVertical_chainStyle="packed"
                    app:layout_constraintTop_toTopOf="@+id/calories_progress_bar"
                    app:layout_constraintBottom_toTopOf="@+id/kalori_label_in_progress"
                    app:layout_constraintStart_toStartOf="@+id/calories_progress_bar"
                    app:layout_constraintEnd_toEndOf="@+id/calories_progress_bar"/>

                 <TextView
                    android:id="@+id/kalori_label_in_progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kalori"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    app:layout_constraintTop_toBottomOf="@+id/calories_text"
                    app:layout_constraintBottom_toBottomOf="@+id/calories_progress_bar"
                    app:layout_constraintStart_toStartOf="@+id/calories_progress_bar"
                    app:layout_constraintEnd_toEndOf="@+id/calories_progress_bar"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Nutrients Section -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/carbs_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#F5DD2F"
            app:cardCornerRadius="20dp"
            app:layout_constraintTop_toBottomOf="@+id/calories_card"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/protein_card">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/carbs_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_carbs"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/carbs_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Karbohidrat"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@+id/carbs_icon"
                    app:layout_constraintStart_toStartOf="parent"/>

                <ProgressBar
                    android:id="@+id/carbs_progress"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:progress="70"
                    android:progressDrawable="@drawable/custom_progress_bar_yellow"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@+id/carbs_label"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <TextView
                    android:id="@+id/carbs_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="140g"
                    android:textColor="#000000"
                    app:layout_constraintTop_toBottomOf="@+id/carbs_progress"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/carbs_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="200g"
                    android:textColor="#000000"
                    app:layout_constraintTop_toBottomOf="@+id/carbs_progress"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/protein_card"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="#4CAF50"
            app:cardCornerRadius="20dp"
            app:layout_constraintTop_toTopOf="@+id/carbs_card"
            app:layout_constraintBottom_toBottomOf="@+id/carbs_card"
            app:layout_constraintStart_toEndOf="@+id/carbs_card"
            app:layout_constraintEnd_toEndOf="parent">

             <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/protein_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_protein"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/protein_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Protein"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@+id/protein_icon"
                    app:layout_constraintStart_toStartOf="parent"/>

                <ProgressBar
                    android:id="@+id/protein_progress"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:progress="50"
                    android:progressDrawable="@drawable/custom_progress_bar_green"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@+id/protein_label"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <TextView
                    android:id="@+id/protein_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="60g"
                    android:textColor="#000000"
                    app:layout_constraintTop_toBottomOf="@+id/protein_progress"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/protein_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="120g"
                    android:textColor="#000000"
                    app:layout_constraintTop_toBottomOf="@+id/protein_progress"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

         <!-- Riwayat Analisis -->
        <TextView
            android:id="@+id/riwayat_analisis_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:text="Riwayat Analisis"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/carbs_card" />

        <LinearLayout
            android:id="@+id/history_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/riwayat_analisis_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- History Item 1 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#2C2C2E"
                app:cardCornerRadius="12dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/history_icon_1"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_carbs"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <TextView
                        android:id="@+id/history_title_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nasi Goreng"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginStart="16dp"
                        app:layout_constraintStart_toEndOf="@id/history_icon_1"
                        app:layout_constraintTop_toTopOf="@id/history_icon_1" />

                    <TextView
                        android:id="@+id/history_subtitle_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="530 Kalori"
                        android:textColor="#EBEBF5"
                        android:textSize="14sp"
                        app:layout_constraintStart_toStartOf="@id/history_title_1"
                        app:layout_constraintTop_toBottomOf="@id/history_title_1" />

                     <TextView
                        android:id="@+id/history_date_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="28 Juni 2024"
                        android:textColor="#98989E"
                        android:textSize="12sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- History Item 2 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#2C2C2E"
                app:cardCornerRadius="12dp">

                 <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/history_icon_2"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_carbs"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/history_title_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ayam Bakar"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginStart="16dp"
                        app:layout_constraintStart_toEndOf="@id/history_icon_2"
                        app:layout_constraintTop_toTopOf="@id/history_icon_2" />

                    <TextView
                        android:id="@+id/history_subtitle_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="350 Kalori"
                        android:textColor="#EBEBF5"
                        android:textSize="14sp"
                        app:layout_constraintStart_toStartOf="@id/history_title_2"
                        app:layout_constraintTop_toBottomOf="@id/history_title_2" />

                     <TextView
                        android:id="@+id/history_date_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="27 Juni 2024"
                        android:textColor="#98989E"
                        android:textSize="12sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- History Item 3 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#2C2C2E"
                app:cardCornerRadius="12dp">

                 <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/history_icon_3"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_carbs"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <TextView
                        android:id="@+id/history_title_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Salad Buah"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginStart="16dp"
                        app:layout_constraintStart_toEndOf="@id/history_icon_3"
                        app:layout_constraintTop_toTopOf="@id/history_icon_3" />

                    <TextView
                        android:id="@+id/history_subtitle_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="150 Kalori"
                        android:textColor="#EBEBF5"
                        android:textSize="14sp"
                        app:layout_constraintStart_toStartOf="@id/history_title_3"
                        app:layout_constraintTop_toBottomOf="@id/history_title_3" />

                     <TextView
                        android:id="@+id/history_date_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="26 Juni 2024"
                        android:textColor="#98989E"
                        android:textSize="12sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
